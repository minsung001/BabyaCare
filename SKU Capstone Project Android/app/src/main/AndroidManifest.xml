<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 🌐 인터넷 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- 🔔 Android 13+ 알림 권한 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- 📳 진동 권한 -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- 🔧 포그라운드 서비스 권한 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication1"
        android:usesCleartextTraffic="true">

        <activity android:name=".GptReportActivity" android:exported="false" />
        <activity android:name=".GrapeActivity" android:exported="false" />
        <activity android:name=".ResetPasswordActivity" android:exported="false" />
        <activity android:name=".policyDetail" android:exported="false" />
        <activity android:name=".userexplore" android:exported="false" />
        <activity android:name=".camera" android:exported="false" />
        <activity android:name=".mypage" android:exported="false" />
        <activity android:name=".EnvironmentActivity" android:exported="false" />
        <activity android:name=".report" android:exported="false" />
        <activity android:name=".policy" android:exported="false" />
        <activity android:name=".Schedule" android:exported="false" />
        <activity android:name=".TermsActivity" android:exported="false" />
        <activity android:name=".SignActivity" android:exported="false" />
        <activity android:name=".Menuactivity" android:exported="false" />

        <!-- 🚀 시작 Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 👶 울음 감지 서비스 -->
        <service
            android:name=".CryAlertService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>

</manifest>